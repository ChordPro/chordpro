      { name : "B^"           copy : "Bmaj7"      display : "BΔ"     },
      // major 9th
      { name : "C^9"          copy : "Cmaj9"      display : "CΔ9"    },
      { name : "C#^9"         copy : "C#maj9"     display : "C#Δ9"   },
      { name : "Db^9"         copy : "Dbmaj9"     display : "DbΔ9"   },
