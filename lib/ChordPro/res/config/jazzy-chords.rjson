      { name : "Bb^9"         copy : "Bbmaj9"     display : "BbΔ9"   },
      { name : "B^9"          copy : "Bmaj9"      display : "BΔ9"    },
      // major 13th
      { name : "C^13"         copy : "Cmaj13"     display : "CΔ13"   },
      { name : "C#^13"        copy : "C#maj13"    display : "C#Δ13"  },
