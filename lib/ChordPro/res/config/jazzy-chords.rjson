      { name : "FmΔ"          copy : "Fm(maj7)"  },
      { name : "F#mΔ"         copy : "F#m(maj7)" },
      { name : "GbmΔ"         copy : "Gbm(maj7)" },
      { name : "GmΔ"          copy : "Gm(maj7)"  },
      { name : "G#mΔ"         copy : "G#m(maj7)" },
      { name : "AbmΔ"         copy : "Abm(maj7)" },
      { name : "AmΔ"          copy : "Am(maj7)"  },
      { name : "A#mΔ"         copy : "A#m(maj7)" },
      { name : "BbmΔ"         copy : "Bbm(maj7)" },
      { name : "BmΔ"          copy : "Bm(maj7)"  },
      // alias
      { name : "Cm(Δ)"        copy : "Cm(maj7)"  },
      { name : "C#m(Δ)"       copy : "C#m(maj7)" },
      { name : "Dbm(Δ)"       copy : "Dbm(maj7)" },
      { name : "Dm(Δ)"        copy : "Dm(maj7)"  },
      { name : "D#m(Δ)"       copy : "D#m(maj7)" },
      { name : "Ebm(Δ)"       copy : "Ebm(maj7)" },
      { name : "Em(Δ)"        copy : "Em(maj7)"  },
      { name : "Fm(Δ)"        copy : "Fm(maj7)"  },
      { name : "F#m(Δ)"       copy : "F#m(maj7)" },
      { name : "Gbm(Δ)"       copy : "Gbm(maj7)" },
      { name : "Gm(Δ)"        copy : "Gm(maj7)"  },
      { name : "G#m(Δ)"       copy : "G#m(maj7)" },
      { name : "Abm(Δ)"       copy : "Abm(maj7)" },
      { name : "Am(Δ)"        copy : "Am(maj7)"  },
      { name : "A#m(Δ)"       copy : "A#m(maj7)" },
      { name : "Bbm(Δ)"       copy : "Bbm(maj7)" },
      { name : "Bm(Δ)"        copy : "Bm(maj7)"  },
      // alias all the major 7th chords using easier-type-type ^, using display to display Δ
      // major 7th
      { name : "C^"           copy : "Cmaj7"      display : "CΔ"     },
      { name : "C#^"          copy : "C#maj7"     display : "C#Δ"    },
      { name : "Db^"          copy : "Dbmaj7"     display : "DbΔ"    },
      { name : "D^"           copy : "Dmaj7"      display : "DΔ"     },
      { name : "D#^"          copy : "D#maj7"     display : "D#Δ"    },
      { name : "Eb^"          copy : "Ebmaj7"     display : "EbΔ"    },
      { name : "E^"           copy : "Emaj7"      display : "EΔ"     },
      { name : "F^"           copy : "Fmaj7"      display : "FΔ"     },
      { name : "F#^"          copy : "F#maj7"     display : "F#Δ"    },
      { name : "Gb^"          copy : "Gbmaj7"     display : "GbΔ"    },
      { name : "G^"           copy : "Gmaj7"      display : "GΔ"     },
      { name : "G#^"          copy : "G#maj7"     display : "G#Δ"    },
