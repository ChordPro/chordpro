      { name : "F#Δ13"        copy : "F#maj13" },
      { name : "GbΔ13"        copy : "Gbmaj13" },
      { name : "GΔ13"         copy : "Gmaj13"  },
      { name : "G#Δ13"        copy : "G#maj13" },
      { name : "AbΔ13"        copy : "Abmaj13" },
      { name : "AΔ13"         copy : "Amaj13"  },
      { name : "A#Δ13"        copy : "A#maj13" },
      { name : "BbΔ13"        copy : "Bbmaj13" },
      { name : "BΔ13"         copy : "Bmaj13"  },
      // minor major 7ths
      { name : "CmΔ"          copy : "Cm(maj7)"  },
      { name : "C#mΔ"         copy : "C#m(maj7)" },
      { name : "DbmΔ"         copy : "Dbm(maj7)" },
