      // minor
      // note: ChordPro recognizes the dash character "-" to mean minor as a built-in chord type and will 
      // provide the corresponding minor chord diagram if one is defined - thus do not need to be defined
      // the minor chords below are defined using the endash character "–" (Unicode hex 2013 or dec 8211)
      // and can be used for readability if desired 
      { name : "C–"           copy : "Cm"   },
      { name : "C#–"          copy : "C#m"  },
      { name : "Db–"          copy : "Dbm"  },
      { name : "D–"           copy : "Dm"   },
      { name : "D#–"          copy : "D#m"  },
      { name : "Eb–"          copy : "Ebm"  },
      { name : "E–"           copy : "Em"   },
