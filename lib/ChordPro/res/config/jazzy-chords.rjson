// supplement and corrections to guitar.json

$schema : "https://chordpro.org/beta/resources/config.schema"

config {
    type        : stylemod
    title       : "Jazzy Chords"
    description : "Over 350 chord name variants typically used in Jazzy music."
}

// first we need to enable "relaxed" chaordnames before defining the chords so they will transpose correctly
settings.chordnames : relaxed

// chord definitions  - this is an array of hashes, one for each chord.
// Each hash should contain the following fields:
//   name :    name of the chord
//   base :    base fret (optional, defaults to 1)
//   frets :   the frets (optional, use 0 for an open string, -1 or "x" for a muted string)
//   fingers : finger positions (optional)
//   display : (optional) change the way the chord is displayed
//   format :  (optional) change the way the name is formatted
// OR copy :   (optional) copy another chord definition (e.g. for enharmonics or alternate names)

// defined herein:
   // jazz notation chord names
      // major 7th
      // major 9th
      // major 13th
      // minor major 7ths
      // minor 7th
      // minor 6th
      // diminished triads 
      // diminished 7th
      // half-diminished (m7b5)
      // half-diminished (m7b5)

chords : [
      // major 7th
      { name : "CΔ"           copy : "Cmaj7"   },
      { name : "C#Δ"          copy : "C#maj7"  },
      { name : "DbΔ"          copy : "Dbmaj7"  },
      { name : "DΔ"           copy : "Dmaj7"   },
      { name : "D#Δ"          copy : "D#maj7"  },
      { name : "EbΔ"          copy : "Ebmaj7"  },
      { name : "EΔ"           copy : "Emaj7"   },
      { name : "FΔ"           copy : "Fmaj7"   },
      { name : "F#Δ"          copy : "F#maj7"  },
      { name : "GbΔ"          copy : "Gbmaj7"  },
      { name : "GΔ"           copy : "Gmaj7"   },
      { name : "G#Δ"          copy : "G#maj7"  },
      { name : "AbΔ"          copy : "Abmaj7"  },
      { name : "AΔ"           copy : "Amaj7"   },
      { name : "A#Δ"          copy : "A#maj7"  },
      { name : "BbΔ"          copy : "Bbmaj7"  },
      { name : "BΔ"           copy : "Bmaj7"   },
      // major 9th
      { name : "CΔ9"          copy : "Cmaj9"   },
      { name : "C#Δ9"         copy : "C#maj9"  },
      { name : "DbΔ9"         copy : "Dbmaj9"  },
      { name : "DΔ9"          copy : "Dmaj9"   },
      { name : "D#Δ9"         copy : "D#maj9"  },
      { name : "EbΔ9"         copy : "Ebmaj9"  },
      { name : "EΔ9"          copy : "Emaj9"   },
      { name : "FΔ9"          copy : "Fmaj9"   },
      { name : "F#Δ9"         copy : "F#maj9"  },
      { name : "GbΔ9"         copy : "Gbmaj9"  },
      { name : "GΔ9"          copy : "Gmaj9"   },
      { name : "G#Δ9"         copy : "G#maj9"  },
      { name : "AbΔ9"         copy : "Abmaj9"  },
      { name : "AΔ9"          copy : "Amaj9"   },
      { name : "A#Δ9"         copy : "A#maj9"  },
      { name : "BbΔ9"         copy : "Bbmaj9"  },
      { name : "BΔ9"          copy : "Bmaj9"   },
      // major 13th
      { name : "CΔ13"         copy : "Cmaj13"  },
      { name : "C#Δ13"        copy : "C#maj13" },
      { name : "DbΔ13"        copy : "Dbmaj13" },
      { name : "DΔ13"         copy : "Dmaj13"  },
      { name : "D#Δ13"        copy : "D#maj13" },
