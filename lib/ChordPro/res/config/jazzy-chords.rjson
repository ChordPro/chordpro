      { name : "Cm(^)"        copy : "Cm(maj7)"   display : "Cm(Δ)"  },
      { name : "C#m(^)"       copy : "C#m(maj7)"  display : "C#m(Δ)" },
      { name : "Dbm(^)"       copy : "Dbm(maj7)"  display : "Dbm(Δ)" },
