{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Debug chordpro",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/script/chordpro.pl", // "script/chordpro.pl",test.pl
            "exec": "perl",
            "execArgs": [],
            "root": "${workspaceRoot}", 
            "inc": ["${workspaceFolder}/lib/", "/workspaces/chordpro/lib/"],
            "args": ["${workspaceFolder}/testing/lowlands.cho","--generate=HTML5", "--output=${workspaceFolder}/testing/lowlands-2.html"],
            "env": {},
            "debugRaw": false,
            "debugLog": false,
            "stopOnEntry": true,
            "sessions": "single"
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Debug chordpro HTML5+ABC",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/script/chordpro.pl",
            "exec": "perl",
            "execArgs": [],
            "root": "${workspaceRoot}",
            "inc": ["${workspaceFolder}/lib"],
            "args": [
                "--no-default-configs",
                "--no-userconfig",
                "--no-sysconfig",
                "--define",
                "debug.abc=1",
                "${workspaceFolder}/testing/lowlands.cho",
                "--generate=HTML5",
                "--output=${workspaceFolder}/testing/lowlands-debug.html"
            ],
            "env": {
                "PERL5LIB": "${workspaceFolder}/lib"
            },
            "debugRaw": false,
            "debugLog": false,
            "stopOnEntry": false,
            "sessions": "single"
        },
        {
            "type": "perl",
            "request": "launch",
            "name": "Perl-Debug md debug test",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/xtest.pl", // "script/chordpro.pl",test.pl
            "exec": "perl",
            "execArgs": [],
            "root": "${workspaceRoot}", 
            "inc": ["/workspace/lib/"],
            "args": ["--no-default-configs","${workspaceFolder}/test_lilypond.cho", "--output=${workspaceFolder}/test.md"],
            // "environment": [{ "PERL5LIB": "/workspace/lib/" }],
            "debugRaw": false,
            "debugLog": false,
            "stopOnEntry": true,
            "sessions": "single"
        }
    ]
}